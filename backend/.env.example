# .env.example — Retention OS 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만들고 실제 값 입력
# cp .env.example .env

# Slack Webhooks
# api.slack.com → 앱 선택 → Incoming Webhooks 에서 복사
SLACK_ALERTS_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
SLACK_URGENT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Linear (스트레치 — 선택)
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=...
